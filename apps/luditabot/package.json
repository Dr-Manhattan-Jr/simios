    "start": "node dist/index.js"
  },
  "dependencies": {
    "@simios/env": "workspace:*",
    "@simios/telegram-kit": "workspace:*",
    "grammy": "^1.32.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
